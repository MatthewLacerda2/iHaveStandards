# Copy to .env and adjust. Never commit the real .env.

# Database — accepts postgres:// / postgresql:// (normalized to postgresql+asyncpg://).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app

# Auth — generate a strong random secret in real deployments.
JWT_SECRET=change-me-in-production
JWT_ISSUER=goldstandard
JWT_AUDIENCE=goldstandard-app
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Seeded on startup if no admin exists.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me

# CORS (comma-separated origins).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
